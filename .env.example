# Glean API credentials
# Get a user-scoped API token with agents + search scopes from your Glean admin.
# Docs: https://developers.glean.com/api-info/client/authentication/glean-issued

GLEAN_API_TOKEN=your-api-token-here

# Your Glean server URL (find at app.glean.com/admin/about-glean → "Server instance (QE)")
GLEAN_SERVER_URL=https://your-company-be.glean.com

# Agent IDs (find in Agent Builder URL: /admin/agents/{agentId})
TARGET_AGENT_ID=your-target-agent-id
JUDGE_AGENT_ID=your-judge-agent-id
