# Glean API credentials
# Get a user-scoped API token with chat, search, and agents scopes.
# Docs: https://developers.glean.com/api-info/client/authentication/glean-issued
GLEAN_API_TOKEN=your-api-token-here

# Your Glean server URL
# Find at: app.glean.com/admin/about-glean → "Server instance (QE)"
GLEAN_SERVER_URL=https://your-company-be.glean.com
